src\\Routes\\Apodrange.jsx",["80","81"],"C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\Routes\\About.jsx",[],"C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\Routes\\Today.jsx",["82"],"C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\RangeVideo.jsx",["83","84","85","86"],"C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\Header.jsx",[],"C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\Footer.jsx",["87","88","89","90"],"const Footer = () => {\r\n\r\n  const date = new Date();\r\n  let year = date.getFullYear();\r\n\r\n  return (\r\n    <footer>\r\n      <div className=\"footer-wrap\">\r\n        <h2 className=\"sr-only\" data-name=\"h2-sr-only-follow-us-on-our-social-media-channels\"></h2>\r\n        <ul className=\"footer-social-links\">\r\n          <li>\r\n            <a href=\"#\" className=\"footer-link\" aria-label=\"twitter\">\r\n              <i aria-hidden=\"true\" className=\"fab fa-twitter\"></i>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"#\" className=\"footer-link\" aria-label=\"facebook\">\r\n              <i aria-hidden=\"true\" className=\"fab fa-facebook\"></i>\r\n            </a>\r\n          </li>\r\n          <li>\r\n            <a href=\"#\" className=\"footer-link\" aria-label=\"instagram\">\r\n              <i aria-hidden=\"true\" className=\"fab fa-instagram\"></i>\r\n            </a>\r\n          </li>\r\n        </ul>  \r\n        <p className=\"disclaimer\">I don't make any money off this. It's just for me, you, and space &hearts;. &copy;{year}</p>\r\n      </div>\r\n    </footer>\r\n  )\r\n}\r\n\r\nexport default Footer\r\n","C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\RangeImage.jsx",["91"],"C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\ApodExp.jsx",[],"C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\NasaObj.jsx",["92","93"],"import { useState } from \"react\";\r\nimport Modal from './Modal.jsx';\r\n\r\nconst NasaObj = (props) => {\r\n\r\n  const [open, setOpen] = useState(false);\r\n\r\n  const obj = props.apod;\r\n\r\n  const openModal = () => {\r\n    if (open) {\r\n      setOpen(false);\r\n    } else {\r\n      setOpen(true);\r\n    }\r\n  }\r\n\r\n  const closeModal = (e) => {\r\n    if (!e.target.classList.contains('modal-img')) {\r\n      setOpen(false);\r\n    }\r\n  }\r\n\r\n  return (\r\n    <>\r\n      {obj.media_type === 'image' \r\n        ? <img className=\"apod-img\" src={obj.url} alt={obj.title} onClick={() => openModal()}/>\r\n        : <iframe className=\"apod-video\" src={obj.url} />}\r\n      <Modal apod={obj} open={open} setOpen={setOpen} />\r\n    </>\r\n  )\r\n}\r\n\r\nexport default NasaObj\r\n","C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\utils\\constants.js",[],"C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\Hooks\\useGetDate.jsx",[],"C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\Hooks\\useGetSingleAPOD.jsx",["94","95"],"import { useEffect, useState } from \"react\";\r\nimport { BASE_API_URL } from '../utils/constants';\r\n\r\nexport default function useGetSingleAPOD(today) {\r\n  const [image, setImage] = useState(null);\r\n\r\n  useEffect(() => {    \r\n\r\n    const getPhoto = () => {\r\n      const response = fetch(`${BASE_API_URL}/api/single-img`, {\r\n        method: 'GET'\r\n      })\r\n      // .then(response => response.json())\r\n      .then(data => {\r\n        setImage(data);\r\n        localStorage.setItem('currentDay', JSON.stringify(data));\r\n      });\r\n    };\r\n\r\n    if (localStorage.getItem('currentDay') === null) {\r\n      getPhoto();\r\n    } else {\r\n      const data = localStorage.getItem('currentDay');\r\n      const newData = JSON.parse(data);\r\n      if (newData.date !== today) {\r\n        getPhoto();\r\n      } else {\r\n        setImage(newData);\r\n      }\r\n      \r\n    }\r\n\r\n  }, []);\r\n\r\n  return image;\r\n}\r\n","C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\Modal.jsx",[],"C:\\Users\\aindo\\OneDrive\\Desktop\\React\\my-apod\\client\\src\\JumpToTopBtn.jsx",["96"],{"ruleId":"97","replacedBy":"98"},{"ruleId":"99","replacedBy":"100"},{"ruleId":"101","severity":1,"message":"102","line":112,"column":6,"nodeType":"103","endLine":112,"endColumn":8,"suggestions":"104"},{"ruleId":"105","severity":1,"message":"106","line":142,"column":39,"nodeType":"107","messageId":"108","endLine":142,"endColumn":41},{"ruleId":"109","severity":1,"message":"110","line":49,"column":9,"nodeType":"111","messageId":"112","endLine":49,"endColumn":65,"fix":"113"},{"ruleId":"114","severity":1,"message":"115","line":6,"column":10,"nodeType":"116","messageId":"117","endLine":6,"endColumn":14},{"ruleId":"114","severity":1,"message":"118","line":6,"column":16,"nodeType":"116","messageId":"117","endLine":6,"endColumn":23},{"ruleId":"101","severity":1,"message":"119","line":12,"column":6,"nodeType":"103","endLine":12,"endColumn":18,"suggestions":"120"},{"ruleId":"121","severity":1,"message":"122","line":29,"column":9,"nodeType":"111","endLine":29,"endColumn":71},{"ruleId":"123","severity":1,"message":"124","line":9,"column":9,"nodeType":"111","endLine":9,"endColumn":95},{"ruleId":"125","severity":1,"message":"126","line":12,"column":13,"nodeType":"111","endLine":12,"endColumn":70},{"ruleId":"125","severity":1,"message":"126","line":17,"column":13,"nodeType":"111","endLine":17,"endColumn":71},{"ruleId":"125","severity":1,"message":"126","line":22,"column":13,"nodeType":"111","endLine":22,"endColumn":72},{"ruleId":"101","severity":1,"message":"119","line":27,"column":6,"nodeType":"103","endLine":27,"endColumn":18,"suggestions":"127"},{"ruleId":"114","severity":1,"message":"128","line":18,"column":9,"nodeType":"116","messageId":"117","endLine":18,"endColumn":19},{"ruleId":"121","severity":1,"message":"122","line":28,"column":11,"nodeType":"111","endLine":28,"endColum